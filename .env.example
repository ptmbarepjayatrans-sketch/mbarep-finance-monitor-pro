# ===== DATABASE =====
DATABASE_URL="postgresql://user:password@localhost:5432/mbarep_finance"

# ===== REDIS =====
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ===== SERVER =====
NODE_ENV="development"
PORT=3000
BACKEND_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:5173"

# ===== JWT =====
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRE="7d"
REFRESH_TOKEN_SECRET="your-refresh-token-secret"
REFRESH_TOKEN_EXPIRE="30d"

# ===== SECURITY =====
API_KEY="your-api-key-here"
ADMIN_DEFAULT_PASSWORD="ChangeMe123!"

# ===== MAIL =====
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
MAIL_FROM="noreply@mbarep.com"

# ===== WHATSAPP =====
WHATSAPP_API_KEY="your-whatsapp-api-key"
WHATSAPP_PHONE="62812345678"

# ===== TELEGRAM =====
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# ===== AI & VOICE =====
OPENAI_API_KEY="sk-your-openai-key"
ELEVEN_LABS_API_KEY="your-elevenlabs-key"
ELEVEN_LABS_VOICE_ID="your-voice-id"

# ===== STORAGE =====
S3_BUCKET="mbarep-finance"
S3_REGION="ap-southeast-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ===== LOGGING =====
LOG_LEVEL="info"
LOG_FORMAT="json"

# ===== ANDROID COLLECTOR =====
ANDROID_DEVICE_KEY="device-key-generated-on-setup"
ANDROID_API_URL="http://localhost:3000/api/v1"
ANDROID_API_KEY="collector-api-key"

# ===== MONITORING =====
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
SENTRY_DSN=""

# ===== FEATURE FLAGS =====
ENABLE_2FA=true
ENABLE_DEVICE_BINDING=true
ENABLE_AI_ASSISTANT=true
ENABLE_VOICE_ANNOUNCEMENT=true
ENABLE_WALLBOARD=true
ENABLE_WEBHOOK=true